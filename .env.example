APPLICATION_ID=
API_KEY=

# WARNING! Please be aware that the scraper sends auth headers to every scraped site, so use `allowed_domains` to adjust the scope accordingly!
# If the scraped site expects an x-auth-token header.
X_AUTH_TOKEN=

# WARNING! Please be aware that the scraper sends auth headers to every scraped site, so use `allowed_domains` to adjust the scope accordingly!
# If the scraped site is behind the CloudFlare Access.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# WARNING! Please be aware that the scraper sends auth headers to every scraped site, so use `allowed_domains` to adjust the scope accordingly!
# If the scraped site is behind the Google Cloud Identity-Aware Proxy
IAP_AUTH_CLIENT_ID=
IAP_AUTH_SERVICE_ACCOUNT_JSON=

CHROMEDRIVER_PATH=

# Optional crawl rate limiting
# Limits the total number of in-flight requests across all domains.
DOCSEARCH_CONCURRENT_REQUESTS=4
# Limits concurrent requests to the same domain.
DOCSEARCH_CONCURRENT_REQUESTS_PER_DOMAIN=1
# Minimum delay in seconds between requests on the same download slot/domain.
DOCSEARCH_DOWNLOAD_DELAY=1
# Whether to randomize the download delay.
DOCSEARCH_RANDOMIZE_DOWNLOAD_DELAY=false
# Lets Scrapy slow down automatically when the target site responds slowly.
DOCSEARCH_AUTOTHROTTLE_ENABLED=true

# Optional Algolia update mode
# atomic keeps the existing _tmp index + move_index behavior.
DOCSEARCH_UPDATE_MODE=atomic
# incremental writes a diff report only unless this is explicitly false.
DOCSEARCH_INCREMENTAL_DRY_RUN=true
# Abort incremental updates when deletes exceed this old-record ratio.
DOCSEARCH_MAX_DELETE_RATIO=0.2
# Optional absolute delete cap for incremental updates.
DOCSEARCH_MAX_DELETE_COUNT=
# Optional JSON report path. Defaults to diff.log in the run directory.
DOCSEARCH_DIFF_REPORT_PATH=

# For internal usage only

APPLICATION_ID_PROD=
API_KEY_PROD=
MONITORING_API_KEY=
# See https://developer.helpscout.com/mailbox-api/overview/authentication/
HELPSCOUT_APP_ID=
HELPSCOUT_APP_SECRET=
NB_HITS_MAX=

# See https://algolia.slack.com/services/B0MUUMGKH
SLACK_HOOK=
PUBLIC_CONFIG_FOLDER=
PRIVATE_CONFIG_FOLDER=

# See with Internal Dashboard team
BASE_INTERNAL_ENDPOINT=
INTERNAL_API_AUTH=

DEPLOY_KEY=
APPLICATION_ID_PROD_INTERNAL=13240
